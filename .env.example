# ─── Core ────────────────────────────────────────────────────────────
NODE_ENV=development              # development | production (affects DB logging, WS CORS, order worker)
PORT=3000                         # HTTP server port

# ─── Database ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/centuari
# When running backend in Docker, use host.docker.internal so the container can reach Postgres on the host:
# DATABASE_URL=postgresql://postgres:password@host.docker.internal:5432/centuari
# Control automatic DB migrations and seeding on app start
MIGRATIONS_ON_START=true           # set to "true" to run migrations on startup; omit/other to skip
SEED_ON_START=true                 # set to "true" to run seeds on startup; omit/other to skip

# ─── NATS ────────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ─── Auth (Privy) ────────────────────────────────────────────────────
PRIVY_APP_ID=
PRIVY_PROJECT_SECRET=

# ─── WebSocket ───────────────────────────────────────────────────────
# Comma-separated origins allowed in production; ignored in development (allows all)
WS_CORS_ORIGINS=https://app.centuari.finance

# ─── Order Worker ────────────────────────────────────────────────────
# Generates fake orders for testing; never runs in production
ORDER_WORKER_ENABLED=true

# ─── Chain Config ────────────────────────────────────────────────────
# Comma-separated chain IDs; each needs a matching RPC_<chainId> var
SUPPORTED_CHAINS=421614
RPC_421614=https://arbitrum-sepolia.drpc.org

# ─── Treasury ──────────────────────────────────────────────────────
TREASURY_ADDRESS=0x122ea513fE68d78CdAD06F982237B1b67a335439

# ─── Faucet (optional) ──────────────────────────────────────────────
OPERATOR_PRIVATE_KEY=
FAUCET_ADDRESS_421614=
FAUCET_TOKENS_421614=
