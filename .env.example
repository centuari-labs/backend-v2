DATABASE_URL=
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_PROJECT_SECRET=
NATS_URL=
NODE_ENV=
PORT=3000  # optional, defaults to 3000
WS_CORS_ORIGINS=
ORDER_WORKER_ENABLED=false
# AUTH_MODE=development # for development only, enables a mock auth strategy that bypasses Privy and returns a fixed user ID and wallet address. Do not enable in production.

# Chain config: one RPC_<chainId> per ID in SUPPORTED_CHAINS
SUPPORTED_CHAINS=8453,421614,11155111
RPC_8453=
RPC_421614=
RPC_11155111=

# Faucet (optional – only needed if using the faucet feature)
OPERATOR_PRIVATE_KEY=
# FAUCET_ADDRESS_<chainId>=  # e.g. FAUCET_ADDRESS_8453
# FAUCET_TOKENS_<chainId>=   # comma-separated token addresses, e.g. FAUCET_TOKENS_8453
