# ─── Core ────────────────────────────────────────────────────────────
NODE_ENV=development              # development | production (affects DB logging, WS CORS, order worker)
PORT=3000                         # HTTP server port

# ─── Database ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/centuari
# When running backend in Docker, use host.docker.internal so the container can reach Postgres on the host:
# DATABASE_URL=postgresql://postgres:password@host.docker.internal:5432/centuari
# Control automatic DB migrations and seeding on app start
MIGRATIONS_ON_START=true           # set to "true" to run migrations on startup; omit/other to skip
SEED_ON_START=true                 # set to "true" to run seeds on startup; omit/other to skip

# ─── NATS ────────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222
# How long (ms) the backend waits for the matching engine's cancel verdict on
# the orders.cancel.request request/reply subject before rejecting the cancel
# with 503. Defaults to 2000.
# NATS_CANCEL_REQUEST_TIMEOUT_MS=2000

# ─── Redis ───────────────────────────────────────────────────────────
# Used by the collateral rate limiter (10 actions/wallet/24h on flag/unflag).
REDIS_URL=redis://localhost:6379

# ─── Smart contracts ─────────────────────────────────────────────────
# All contract addresses are auto-managed in .env.contracts (synced from
# smart-contract-revamp/bin/sync-to-services.sh). Do not set them here.
# Available addresses after sync: HUB_DEPOSITOR_ADDRESS, BALANCE_LEDGER_ADDRESS,
# CENTUARI_ADDRESS, COLLATERAL_MANAGER_ADDRESS, RISK_MODULE_ADDRESS,
# WITHDRAWAL_REGISTRY_ADDRESS, FAUCET_ADDRESS_<chainId>, FAUCET_TOKENS_<chainId>.
# - CollateralManager: backend calls `unflagFor` via the operator key. Frontend
#   (Phase 5) calls `flag(asset)` / `unflag(asset)` directly via wagmi.
# - RiskModule: backend calls `canUnflag(user, asset)` view via `readContract`
#   to short-circuit unflag requests that would revert.

# ─── Auth (Privy) ────────────────────────────────────────────────────
# Both are required — the service throws at boot if either is empty.
# Mainnet and testnet use SEPARATE Privy apps: in prod set the mainnet app's
# credentials, and PRIVY_APP_ID MUST equal the frontend NEXT_PUBLIC_PRIVY_APP_ID
# (the backend verifies the auth token the frontend mints).
PRIVY_APP_ID=
PRIVY_PROJECT_SECRET=

# ─── Access Code Admin ──────────────────────────────────────────────
# Secret token for access code management endpoints (generate, list, deactivate)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACCESS_CODE_ADMIN_SECRET=

# ─── WebSocket ───────────────────────────────────────────────────────
# Comma-separated origins allowed in production; ignored in development (allows all)
WS_CORS_ORIGINS=https://app.centuari.finance

# ─── Order Worker ────────────────────────────────────────────────────
# Market-making bot that seeds lend/borrow liquidity. This flag is the SOLE
# gate (independent of NODE_ENV) — it runs on testnet even under
# NODE_ENV=production. WARNING: never set this to true on mainnet.
ORDER_WORKER_ENABLED=true
# Funding targets per bot (human units). Lower values = faster funding cycles, fewer faucet rounds.
# ORDER_WORKER_MIN_HUB_DEPOSITOR_BALANCE=10000  # optional; default 10000 loan tokens
# ORDER_WORKER_MIN_COLLATERAL_BALANCE=100    # optional; default 100 collateral tokens

# ─── Chain Config ────────────────────────────────────────────────────
# Comma-separated chain IDs; each needs a matching RPC_<chainId> var
SUPPORTED_CHAINS=421614
RPC_421614=https://arbitrum-sepolia.drpc.org

# ─── Chain Indexer ────────────────────────────────────────────────────
# Polls on-chain events (e.g. HubDepositor Deposited events) and syncs to DB
CHAIN_INDEXER_ENABLED=true
INDEXER_START_BLOCK=0                # block to start from on first run
INDEXER_POLL_INTERVAL_MS=10000       # poll interval in ms (default: 10000)

# ─── Operator key ────────────────────────────────────────────────────
# Used by faucet, chain-indexer, withdraw, and orders worker for signing
# operator-path transactions. FAUCET_ADDRESS_<chainId> and
# FAUCET_TOKENS_<chainId> are auto-managed in .env.contracts.
OPERATOR_PRIVATE_KEY=

# Dedicated signing key for the oracle price-push keeper (OraclePushWorker).
# Leave empty to reuse OPERATOR_PRIVATE_KEY (the default today). To run the
# keeper under a SEPARATE operator later, set this key here AND rotate each
# PushOracle's on-chain operator to its address (PushOracle.setOperator,
# owner-gated) so setPrice is authorized.
ORACLE_PUSH_OPERATOR_PRIVATE_KEY=
