{
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": ".",
    "roots": ["<rootDir>/src/__test__/integration"],
    "testRegex": ".*\\.integration\\.test\\.ts$",
    "transform": {
        "^.+\\.(t|j)s$": "ts-jest"
    },
    "transformIgnorePatterns": ["node_modules/(?!jose)"],
    "moduleNameMapper": {
        "^@/(.*)$": "<rootDir>/src/$1",
        "^src/(.*)$": "<rootDir>/src/$1",
        "^@centuari-labs/on-chain-effects$": "<rootDir>/src/__test__/stubs/on-chain-effects.stub.ts"
    },
    "testEnvironment": "node",
    "testTimeout": 30000
}
