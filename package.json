{
    "name": "backend-v2",
    "version": "0.0.1",
    "description": "",
    "author": "",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "build": "nest build",
        "migrate": "ts-node src/core/database/scripts/run-migration.ts",
        "seed": "ts-node src/core/database/scripts/run-seed.ts",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/src/main",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "test:integration": "jest --config ./jest-integration.config.json",
        "test:integration:price": "node -r dotenv/config node_modules/jest/bin/jest.js src/__test__/price/providers/coingecko-tokens.integration.test.ts",
        "lint": "biome check --write .",
        "format": "biome format --write .",
        "db": "ts-node src/core/database/scripts/db.ts"
    },
    "dependencies": {
        "@nestjs/common": "^11.0.1",
        "@nestjs/config": "^4.0.3",
        "@nestjs/core": "^11.0.1",
        "@nestjs/jwt": "^11.0.1",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/platform-express": "^11.0.1",
        "@nestjs/platform-socket.io": "^11.1.13",
        "@nestjs/schedule": "^6.1.1",
        "@nestjs/typeorm": "^11.0.0",
        "@nestjs/websockets": "^11.1.13",
        "@privy-io/server-auth": "^1.32.5",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.3",
        "dotenv": "^17.2.3",
        "express": "^5.2.1",
        "jose": "^6.1.2",
        "nats": "^2.29.3",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "pg": "^8.16.3",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "socket.io": "^4.8.3",
        "typeorm": "^0.3.28",
        "viem": "^2.38.6",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@biomejs/biome": "2.3.4",
        "@nestjs/cli": "^11.0.0",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.0.1",
        "@types/express": "^5.0.0",
        "@types/jest": "^30.0.0",
        "@types/node": "^22.10.7",
        "@types/pg": "^8.15.6",
        "@types/supertest": "^6.0.2",
        "commander": "^14.0.2",
        "globals": "^16.0.0",
        "jest": "^30.0.0",
        "socket.io-client": "^4.8.3",
        "source-map-support": "^0.5.21",
        "supertest": "^7.0.0",
        "ts-jest": "^29.2.5",
        "ts-loader": "^9.5.2",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.7.3"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": ".",
        "roots": [
            "<rootDir>/src/__test__"
        ],
        "testRegex": ".*\\.test\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "transformIgnorePatterns": [
            "node_modules/(?!jose)"
        ],
        "moduleNameMapper": {
            "^@/(.*)$": "<rootDir>/src/$1",
            "^src/(.*)$": "<rootDir>/src/$1"
        },
        "collectCoverageFrom": [
            "src/**/*.(t|j)s"
        ],
        "coverageDirectory": "./coverage",
        "testEnvironment": "node"
    },
    "packageManager": "pnpm@10.29.2+sha512.bef43fa759d91fd2da4b319a5a0d13ef7a45bb985a3d7342058470f9d2051a3ba8674e629672654686ef9443ad13a82da2beb9eeb3e0221c87b8154fff9d74b8"
}
