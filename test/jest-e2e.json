{
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": ".",
    "testEnvironment": "node",
    "testRegex": ".e2e-spec.ts$",
    "transform": {
        "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
        "^jose$": "<rootDir>/__mocks__/jose.ts",
        "^@privy-io/server-auth$": "<rootDir>/__mocks__/@privy-io/server-auth.ts"
    }
}
